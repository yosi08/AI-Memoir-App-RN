{
  "expo": {
    "name": "AI Memoir",
    "slug": "ai-memoir",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.memoir.ai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F5"
      },
      "package": "com.memoir.ai"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Memoir to access your camera to create your AI self."
        }
      ]
    ]
  }
}
